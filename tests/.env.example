# REDCap community portal credentials
# Required for all tests that download REDCap
REDCAP_COMMUNITY_USER=
REDCAP_COMMUNITY_PASSWORD=

# REDCap version to install in fresh-install and reconciler tests
REDCAP_TEST_VERSION=14.9.4

# REDCap version to upgrade to — must be strictly greater than REDCAP_TEST_VERSION.
# Use adjacent minor versions so upgrade tests are fast.
REDCAP_TEST_UPGRADE_VERSION=14.9.5

# Docker image to test.
# Leave this blank when using ./run-tests.sh — it builds the local image
# automatically and sets this variable before starting the test runner.
# Set it explicitly only if you want to test a specific pre-built image tag.
REDCAP_DOCKER_IMAGE=
